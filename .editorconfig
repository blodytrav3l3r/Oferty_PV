root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.bat]
end_of_line = crlf

[*.{cmd,ps1}]
end_of_line = crlf

[*.{png,jpg,jpeg,gif,ico,woff,woff2,ttf,eot,otf,svg}]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset

[*.{sqlite,db,exe,dll,obj}]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
