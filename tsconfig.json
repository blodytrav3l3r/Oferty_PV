{
    "compilerOptions": {
        "target": "ES2021",
        "module": "commonjs",
        "lib": ["ES2021"],
        "outDir": "./dist",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "moduleResolution": "node10",
        "allowSyntheticDefaultImports": true,
        "noImplicitAny": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "strictNullChecks": true,
        "ignoreDeprecations": "6.0",
        "types": ["jest", "node", "supertest"]
    },
    "include": ["src/**/*.ts", "server.ts", "scripts/**/*.ts", "tests/**/*.ts"],
    "exclude": ["node_modules", "dist", "public", "data", "*.sqlite"]
}
