{
    "name": "witros-oferty",
    "version": "2.0.0",
    "main": "dist/server.js",
    "scripts": {
        "start": "node dist/server.js",
        "dev": "ts-node-dev --respawn --transpile-only server.ts",
        "dev:frontend": "vite",
        "build": "tsc",
        "build:frontend": "vite build",
        "build:watch": "tsc --watch",
        "preview:frontend": "vite preview",
        "test": "jest --coverage",
        "test:watch": "jest --watch",
        "lint": "eslint src/**/*.{js,ts}",
        "lint:fix": "eslint src/**/*.{js,ts} --fix",
        "lint:frontend": "eslint public/js --ext .js",
        "typecheck": "tsc --noEmit",
        "typecheck:frontend": "tsc -p tsconfig.frontend.json",
        "format": "prettier --write \"**/*.{js,ts,json,md}\"",
        "format:check": "prettier --check \"**/*.{js,ts,json,md}\"",
        "backup": "ts-node scripts/backup.ts",
        "backup:install-cron": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-backup-cron.ps1",
        "backup:uninstall-cron": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-backup-cron.ps1",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:deploy": "prisma migrate deploy",
        "prisma:status": "prisma migrate status",
        "prisma:reset": "prisma migrate reset",
        "prisma:studio": "prisma studio",
        "graphify:watch": "graphify watch .",
        "graphify:update": "graphify update .",
        "graphify:ast-update": "powershell -NoProfile -NonInteractive -Command \"& (Get-Content graphify-out/.graphify_python) scripts/graphify_ast_update.py\"",
        "graphify:query": "graphify query",
        "graphify:status": "graphify status .",
        "graphify:ci": "graphify build .",
        "predev": "where graphify >nul 2>&1 || (echo [WARN] graphify nie znaleziony. Uruchom: npm i -g graphify && exit /b 0)"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "WITROS Oferty - Generator ofert handlowych (TypeScript + Prisma)",
    "dependencies": {
        "@eslint-community/eslint-utils": "^4.9.1",
        "@prisma/client": "^6.0.0",
        "bcryptjs": "^3.0.3",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "docx": "^9.6.1",
        "docxtemplater": "^3.68.4",
        "dotenv": "^17.4.1",
        "express": "^4.21.0",
        "helmet": "^8.1.0",
        "html-docx-js-typescript": "^0.1.5",
        "jszip": "^3.10.1",
        "pizzip": "^3.2.0",
        "prisma": "^6.0.0",
        "puppeteer": "^24.40.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.8.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^4.17.21",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.6.0",
        "@types/supertest": "^7.2.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-node": "^11.1.0",
        "globals": "^17.4.0",
        "jest": "^30.3.0",
        "prettier": "^3.8.2",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.9",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.1",
        "vite": "^8.0.14"
    }
}
