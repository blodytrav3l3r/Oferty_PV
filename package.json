{
    "name": "witros-oferty",
    "version": "1.8.0",
    "main": "dist/server.js",
    "scripts": {
        "start": "node dist/server.js",
        "dev": "concurrently -k -n backend,frontend -c cyan,green \"npm run dev:backend\" \"node scripts/wait-and-start.mjs\"",
        "dev:backend": "ts-node-dev --respawn --transpile-only ./server.ts",
        "dev:frontend": "vite",
        "build": "tsc",
        "build:frontend": "vite build",
        "build:watch": "tsc --watch",
        "preview:frontend": "vite preview",
        "test": "jest --coverage",
        "test:watch": "jest --watch",
        "test:quick": "jest --no-coverage",
        "test:alignment": "node tests/playwright/excelEmptyRowAlignment.cjs",
        "validate": "npm run typecheck && npm run typecheck:frontend && npm run lint && npm run lint:frontend && npm run test:quick",
        "lint": "eslint src/**/*.{js,ts}",
        "lint:fix": "eslint src/**/*.{js,ts} --fix",
        "lint:frontend": "eslint public/js --ext .js",
        "typecheck": "tsc --noEmit",
        "typecheck:frontend": "tsc -p tsconfig.frontend.json",
        "format": "prettier --write \"**/*.{js,ts,json,md}\"",
        "format:check": "prettier --check \"**/*.{js,ts,json,md}\"",
        "backup": "ts-node scripts/backup.ts",
        "backup:install-cron": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-backup-cron.ps1",
        "backup:uninstall-cron": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-backup-cron.ps1",
        "prisma:seed": "ts-node prisma/seed.ts",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:deploy": "prisma migrate deploy",
        "prisma:status": "prisma migrate status",
        "prisma:reset": "prisma migrate reset",
        "prisma:studio": "prisma studio",
        "release": "standard-version",
        "version:check": "node scripts/check-version.mjs",
        "version:patch": "node scripts/bump-version.mjs patch",
        "version:minor": "node scripts/bump-version.mjs minor",
        "version:major": "node scripts/bump-version.mjs major",
        "version:bump": "node scripts/bump-version.mjs",
        "skills:build": "node scripts/skill-cli.mjs build-cost",
        "skills:stats": "node scripts/skill-cli.mjs stats",
        "skills:validate": "node scripts/skill-cli.mjs validate",
        "skills:cost": "node scripts/skill-cli.mjs cost",
        "skills:deps": "node scripts/skill-cli.mjs deps",
        "skills:plan": "node scripts/skill-cli.mjs plan",
        "skills:capabilities": "node scripts/skill-cli.mjs capabilities",
        "skills:provider-resolve": "node scripts/skill-cli.mjs provider-resolve",
        "skills:feedback-record": "node scripts/skill-cli.mjs feedback-record",
        "skills:feedback-show": "node scripts/skill-cli.mjs feedback-show",
        "skills:utility-recalc": "node scripts/skill-cli.mjs utility-recalc",
        "release:minor": "standard-version --release-as minor",
        "release:patch": "standard-version --release-as patch",
        "release:major": "standard-version --release-as major",
        "release:dry": "standard-version --dry-run",
        "release:first": "standard-version --first-release",
        "encoding:check": "node scripts/encoding-integrity.js check",
        "encoding:fix": "node scripts/encoding-integrity.js fix",
        "encoding:staged": "node scripts/encoding-integrity.js staged",
        "docs:erd": "prisma generate --generator erd",
        "docs:typedoc": "typedoc --options docs/typedoc.json",
        "docs:api": "node scripts/auto-docs-version.mjs && npm run docs:erd && npm run docs:typedoc",
        "docs:generate": "npm run docs:api",
        "prepare": "husky"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "keywords": [],
    "author": "",
    "license": "SEE LICENSE IN LICENSE",
    "description": "WITROS Oferty - Generator ofert handlowych (TypeScript + Prisma)",
    "dependencies": {
        "@eslint-community/eslint-utils": "^4.9.1",
        "@prisma/client": "^6.0.0",
        "@sentry/node": "^10.59.0",
        "bcryptjs": "^3.0.3",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "docx": "^9.6.1",
        "dotenv": "^17.4.1",
        "express": "^4.21.0",
        "helmet": "^8.1.0",
        "puppeteer": "^24.40.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.1.0",
        "@commitlint/config-conventional": "^21.0.2",
        "@eslint/js": "^9.39.4",
        "@prisma/generator-helper": "^7.8.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.8.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^4.17.21",
        "@types/jest": "^30.0.0",
        "@types/node": "^26.0.1",
        "@types/supertest": "^7.2.0",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "concurrently": "^10.0.3",
        "esbuild": "^0.28.1",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "js-yaml": "^4.2.0",
        "lint-staged": "^17.0.7",
        "prettier": "^3.9.4",
        "prisma": "^6.0.0",
        "prisma-erd-generator": "^2.4.4",
        "rollup-plugin-visualizer": "^7.0.1",
        "standard-version": "^9.5.0",
        "supertest": "^7.2.2",
        "swagger-jsdoc": "^6.3.0",
        "swagger-ui-express": "^5.0.1",
        "ts-jest": "^29.4.9",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typedoc": "^0.28.20",
        "typedoc-plugin-markdown": "^4.12.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.62.1",
        "vite": "^8.0.14",
        "wait-on": "^9.0.10"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    },
    "lint-staged": {
        "*.{js,ts,mjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,css,html}": [
            "prettier --write"
        ],
        "*.{html,css,js,ts,json,md,yml,yaml,sql,xml,mjs,cjs}": [
            "node scripts/encoding-integrity.js staged"
        ]
    }
}
