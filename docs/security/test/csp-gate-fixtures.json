            ],
            "expectedExit": 0,
            "expectedCheck1New": 0,
            "expectedCheck2Reverted": 0
        },
        {
            "name": "baseline-v1-compat",
            "description": "Wersja z v1 baseline (array zamiast {meta, entries}) — backward compatibility",
            "v2Baseline": [{ "fingerprint": "aaa111", "status": "VERIFIED" }],
            "currentEntries": [
                {
                    "fingerprint": "aaa111",
                    "classification": "INLINE_HTML_HANDLER",
                    "subclassification": "MIGRATED",
                    "status": "VERIFIED",
                    "file": "migrated"
                }
            ],
            "expectedExit": 0,
            "expectedCheck1New": 0,
            "expectedCheck2Reverted": 0
        },
        {
            "name": "unknown-action-fails",
            "description": "data-action w kodzie nie ma kontraktu → FAIL Check 3",
            "v2Baseline": [],
            "currentEntries": [],
            "contracts": {
                "actions": {
                    "closeModal": {
                        "description": "Close modal",
                        "params": [],
                        "handler": "closeModal"
                    }
                }
            },
            "actionUsage": {
                "closeModal": { "src": ["register"] },
                "unknownAction": { "src": ["html"] }
            },
            "expectedExit": 1,
            "expectedCheck1New": 0,
            "expectedCheck2Reverted": 0,
            "expectedCheck3Unknown": 1
        },
        {
            "name": "legacy-action-doesnt-fail",
            "description": "data-action z handledBy:legacy → NIE jest nieznane, PASS",
            "v2Baseline": [],
            "currentEntries": [],
            "contracts": {
                "actions": {
                    "closeModal": {
                        "description": "Close modal",
                        "params": [],
                        "handler": "closeModal"
                    },
                    "legacyAction": {
                        "description": "Legacy action",
                        "params": [],
                        "handler": "legacyHandler",
                        "handledBy": "legacy"
                    }
                }
            },
            "actionUsage": {
                "closeModal": { "src": ["register"] },
                "legacyAction": { "src": ["html"] }
            },
            "expectedExit": 0,
            "expectedCheck1New": 0,
            "expectedCheck2Reverted": 0,
            "expectedCheck3Unknown": 0
        },
        {
            "name": "all-three-checks-pass",
            "description": "Migracja OK, reintroduction 0, unknown actions 0 → PASS",
            "v2Baseline": [{ "fingerprint": "aaa111", "status": "VERIFIED" }],
            "currentEntries": [
                {
                    "fingerprint": "aaa111",
                    "classification": "INLINE_HTML_HANDLER",
                    "subclassification": "MIGRATED",
                    "status": "VERIFIED",
                    "file": "migrated"
                }
            ],
            "contracts": {
                "actions": {
                    "closeModal": {
                        "description": "Close modal",
                        "params": [],
                        "handler": "closeModal"
                    }
                }
            },
            "actionUsage": {
                "closeModal": { "src": ["register", "html"] }
            },
            "expectedExit": 0,
            "expectedCheck1New": 0,
            "expectedCheck2Reverted": 0,
            "expectedCheck3Unknown": 0
        }
    ]
