{
  "compilerOptions": {
    "target": "ES2021",
    "module": "none",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "public/js/**/*.js",
    "public/data/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "data",
    "*.sqlite"
  ]
}
