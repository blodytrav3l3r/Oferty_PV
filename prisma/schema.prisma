// Schemat bazy danych Prisma dla systemu WITROS Oferty
// Ten plik definiuje modele danych dla SQLite

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}



datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Logi telemetryczne AI o nadpisaniach użytkownika
model ai_telemetry_logs {
  id                   String   @id
  userId               String?
  original_auto_config String?
  final_user_config    String?
  override_reason      String?
  createdAt            String?

  // ─── Kontekst studni ───
  offerId              String?
  wellId               String?
  clientId             String?
  projectId            String?
  warehouse            String?

  // ─── Parametry wejściowe studni (snapshot) ───
  dn                   String?
  rzDna                Float?
  rzWlazu              Float?
  wellHeight           Float?
  wellType             String?
  terminationType      String?
  reductionType        String?
  zwiencenieType       String?
  dennicaType          String?
  dennicaHeight        Float?
  ringCount            Int?
  ringHeights          String? // JSON array

  // ─── Redukcje, zakończenia (snapshot) ───
  appliedReductions    String? // JSON array
  appliedKonus         String? // JSON array
  appliedHatches       String? // JSON array
  appliedSeals         String? // JSON array
  allComponentIds      String? // JSON array

  // ─── Solver metadata ───
  solverSource         String? // 'AUTO_JS' | 'MANUAL'
  solverVersion        String?
  rulesVersion         String?
  aiVersion            String?
  computationMs        Int?
  iterationCount       Int?
  checkedVariants      Int?
  rankingScore         Float?
  selectionReason      String?
  wasAutoGenerated     Boolean  @default(false)
  wasAccepted          Boolean  @default(false)
  wasRejected          Boolean  @default(false)
  wasModified          Boolean  @default(false)
  modificationCount    Int?     @default(0)
  confidenceScore      Float?
  learningWeight       Float?
  trainingEligible     Boolean  @default(true)
  feedbackProcessed    Boolean  @default(false)

  // ─── Configuration version (history) ───
  configVersion        Int?     @default(1)
  parentConfigId       String?
  reviewStatus         String?  @default("active")  // 'active' | 'archived' | 'shadowed'

  // ─── Pola przygotowane pod przyszłe AI ───
  featureSnapshot      String?  // JSON: cechy wejściowe (features)
  labelSnapshot        String?  // JSON: wynik / decyzja (labels)
  predictionSnapshot   String?  // JSON: przewidywania AI (predictions) — puste gdy brak AI
  rewardValue          Float?   // JSON: nagroda - przyszłe wyk restricted
  successRate          Float?
  usageCount           Int?     @default(1)
  lastUsedAt           String?
  lastAcceptedAt       String?
  lastRejectedAt       String?
  manualOverrideFlag   Boolean  @default(false)

  // ─── Nowe kolumny dodane przez przyszłą ewolucję AI ───
  extraMeta            String?  // JSON: miejsce na dowolne dodatkowe pola

  @@index([wasModified], map: "idx_logs_wasmodified")
  @@index([createdAt], map: "idx_logs_createdat")
  @@index([dn], map: "idx_logs_dn")
  @@index([wasModified, createdAt], map: "idx_logs_modified_created")
}

// Zdarzenia telemetrii (user actions, zmiany, akceptacje, odrzucenia) - polling feed
model ai_telemetry_events {
  id            String  @id
  telemetryId   String?
  eventType     String  // 'auto_run' | 'user_change' | 'accept' | 'reject' | 'save_offer' | 'create_order'
  userId        String?
  wellId        String?
  componentId   String?
  previousValue String?
  newValue      String?
  changeReason  String?
  msSinceConfig Int?
  orderInSession Int?
  sequenceNo    Int?    @default(0)
  createdAt     String?

  @@index([telemetryId], map: "idx_events_telemetry")
  @@index([wellId], map: "idx_events_well")
  @@index([eventType], map: "idx_events_type")
  @@index([userId], map: "idx_events_user")
  @@index([createdAt], map: "idx_events_createdat")
}

// Wersje konfiguracji - pelna historia bez nadpisywania (każda modyfikacja = nowa wersja)
model ai_config_history {
  id              String  @id
  wellId          String?
  configVersion   Int
  parentId        String?
  configJson      String?
  source          String?  // 'AUTO_JS' | 'MANUAL' | 'AI_SUGGEST'
  triggeredBy     String?  // userId
  diffFromParent  String?  // JSON: lista zmian elementów
  isCurrent       Boolean @default(true)
  rankingScore    Float?
  selectionReason String?
  createdAt       String?

  @@index([wellId], map: "idx_history_well")
  @@index([wellId, isCurrent], map: "idx_history_well_current")
}

// Wersje solvera i reguł - do audit i reprodukcji
model ai_telemetry_versions {
  id            String  @id
  componentType String  // 'solver' | 'rules' | 'ai' | 'embedding'
  version       String
  description   String?
  schemaVersion String?
  isActive      Boolean @default(true)
  appliedFrom   String?
  createdAt     String?

  @@index([componentType, isActive], map: "idx_versions_active")
}

// Baza wiedzy AI - zapisywane wzorce i rekomendacje nie modyfikują solvera
model ai_knowledge_base {
  id              String  @id
  patternType     String  // 'dennica_swap' | 'ring_pattern' | 'reduction_choice'
  patternKey      String
  dn              String?
  context         String?
  description     String?
  recommendation  String?
  hitCount        Int     @default(0)
  confidence      Float   @default(0.0)
  successCount    Int     @default(0)
  rejectionCount  Int     @default(0)
  firstDetectedAt String?
  lastHitAt       String?
  lastUpdatedAt   String?
  changeHistory   String?
  status          String  @default("active")
  schemaVersion   String?
  generatedBy     String?

  @@index([patternType], map: "idx_kb_pattern_type")
  @@index([dn], map: "idx_kb_dn")
  @@index([patternKey], map: "idx_kb_pattern_key")
  @@index([status], map: "idx_kb_status")
  @@index([confidence], map: "idx_kb_confidence")
}

// Rekomendacje AI - wygenerowane, ale niewpływające na solver
model ai_recommendations {
  id            String  @id
  patternType   String
  patternKey    String
  dn            String?
  wellId        String?
  score         Float   @default(0.0)
  confidence    Float   @default(0.0)
  payload       String?
  wasApplied    Boolean @default(false)
  wasAccepted   Boolean @default(false)
  wasRejected   Boolean @default(false)
  generatedAt   String?
  decidedAt     String?
  decidedBy     String?

  @@index([patternType], map: "idx_recs_type")
  @@index([wellId], map: "idx_recs_well")
  @@index([wasApplied], map: "idx_recs_applied")
}

// Przejscia szczelne (geometric features) - wydzielone od zwyklych komponentow
model ai_transition_snapshots {
  id           String  @id
  wellId       String?
  configId     String?
  transitionNo Int?
  dn           String?
  transitionType String?
  producer     String?
  heightFromBottomMm Float?
  angleDeg     Float?
  position     String?
  collided     Boolean @default(false)
  affectedDennicaHeight Float?
  affectedRingSelection  Boolean @default(false)
  affectedReductionChoice Boolean @default(false)
  affectedFinalConfig    Boolean @default(false)
  minimalDennicaForTransitionsMm Float?
  solverModifiedForTransitions Boolean @default(false)
  createdAt    String?

  @@index([wellId], map: "idx_transitions_well")
  @@index([configId], map: "idx_transitions_config")
}

// Logi audytowe (śledzenie zmian w bazie)
model audit_logs {
  id         String   @id
  entityType String
  entityId   String
  userId     String?
  action     String
  oldData    String?
  newData    String?
  createdAt  String?

  @@index([entityType, entityId], map: "idx_audit_entity")
  @@index([createdAt], map: "idx_audit_created_at")
}

// Baza klientów
model clients_rel {
  id        String  @id
  userId    String?
  name      String?
  nip       String?
  address   String?
  email     String?
  phone     String?
  contact       String? @default("")
  clientNumber  String? @default("")
  createdAt     String?
  updatedAt     String?

  @@index([userId], map: "idx_clients_user")
}

model offer_items_rel {
  id        String  @id
  offerId   String?
  productId String?
  quantity  Float?
  discount  Float?
  price     Float?

  @@index([offerId], map: "idx_offitems_offer")
}

model offer_studnie_items_rel {
  id             String  @id
  offerId        String?
  productId      String?
  quantity       Float?
  discount       Float?
  price          Float?
  dodatkowe_info String?

  @@index([offerId], map: "idx_offstitems_offer")
}

// Główne dokumenty ofert (typ rury/ogólne)
model offers_rel {
  id            String   @id
  userId        String?
  clientId      String?
  state         String?
  createdAt     String?
  transportCost Float?
  offer_number  String?
  data          String?
  updatedAt     String?
  history       String?  @default("[]")
  clientName    String?
  investName    String?
  clientNip     String?

  @@index([userId], map: "idx_offers_user")
  @@index([createdAt], map: "idx_offers_created")
  @@index([state], map: "idx_offers_state")
  @@index([offer_number], map: "idx_offers_number")
  @@index([clientName], map: "idx_offers_clientname")
  @@index([investName], map: "idx_offers_investname")
}

// Główne dokumenty ofert (typ studnie)
model offers_studnie_rel {
  id            String   @id
  userId        String?
  clientId      String?
  state         String?
  createdAt     String?
  transportCost Float?
  offer_number  String?
  data          String?
  updatedAt     String?
  history       String?  @default("[]")
  clientName    String?
  investName    String?
  clientNip     String?

  @@index([userId], map: "idx_offersstud_user")
  @@index([createdAt], map: "idx_offersstud_created")
  @@index([state], map: "idx_offersstud_state")
  @@index([offer_number], map: "idx_offersstud_number")
  @@index([clientName], map: "idx_offersstud_clientname")
  @@index([investName], map: "idx_offersstud_investname")
}

// Liczniki numeracji ofert
model order_counters {
  userId     String
  year       Int
  lastNumber Int?    @default(0)

  @@id([userId, year])
}

// Liczniki numeracji zamówień rur (niezależne od studni)
model order_counters_rury {
  userId     String
  year       Int
  lastNumber Int?    @default(0)

  @@id([userId, year])
}

// Zamówienia na studnie
model orders_studnie_rel {
  id             String  @id
  userId         String?
  offerStudnieId String?
  createdAt      String?
  status         String?
  data           String?

  @@index([userId], map: "idx_ordstud_user")
  @@index([offerStudnieId], map: "idx_ordstud_offer")
}

// Zamówienia na rury
model orders_rury_rel {
  id        String  @id
  userId    String?
  offerId   String?
  createdAt String?
  status    String?
  data      String?

  @@index([userId], map: "idx_ordrury_user")
  @@index([offerId], map: "idx_ordrury_offer")
}

model production_order_counters {
  userId     String
  year       Int
  lastNumber Int?   @default(0)

  @@id([userId, year])
}

model production_orders_rel {
  id           String  @id
  userId       String?
  orderId      String?
  wellId       String?
  elementIndex Int?
  createdAt    String?
  updatedAt    String?
  data         String?
  creatorId    String? @default("")

  @@index([userId], map: "idx_prod_user")
  @@index([creatorId], map: "idx_prod_creator")
  @@index([createdAt], map: "idx_prod_created")
  @@index([orderId], map: "idx_prod_order")
}

model recycled_production_numbers {
  userId    String
  year      Int
  seqNumber Int

  @@id([userId, year, seqNumber])
}

model sessions {
  token     String @id
  userId    String
  createdAt BigInt
}

model settings {
  key   String @id
  value String?
}

