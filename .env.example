# ==============================================
# WITROS Oferty — Konfiguracja środowiskowa
# ==============================================
# Skopiuj ten plik jako .env i dostosuj wartości
# cp .env.example .env
# ==============================================

# Port na którym nasłuchuje serwer (domyślnie 3000)
# Dla Dockera: docker-compose.yml ustawia PORT=10000 wewnątrz kontenera
PORT=3000

# Adres nasłuchiwania (0.0.0.0 = dostępny z sieci)
# NIE ZMIENIAJ na 127.0.0.1 — aplikacja nie będzie dostępna z zewnątrz
HOST=0.0.0.0

# Tryb pracy: 'development' lub 'production'
# W trybie produkcji:
# - pliki statyczne są cache'owane (szybsze ładowanie)
# - nagłówki bezpieczeństwa są aktywne
NODE_ENV=production

# ==============================================
# Bezpieczeństwo — WYMAGANE przy pierwszym uruchomieniu
# ==============================================
# Hasło administratora (min. 6 znaków)
# UWAGA: Jeśli nie ustawisz tej wartości, aplikacja NIE utworzy konta admina
DEFAULT_ADMIN_PASSWORD=anim123456

# ==============================================
# Monitorowanie błędów — Sentry (opcjonalnie)
# ==============================================
# DSN z https://sentry.io/settings/projects/ — jeśli pusty, Sentry wyłączony
SENTRY_DSN=

# ==============================================
# Baza danych SQLite
# ==============================================
# Domyślnie Prisma szuka względem folderu prisma/, więc ścieżka
# file:../data/app_database.sqlite wskazuje na /app/data/...
# Dla Dockera: file:/var/data/app_database.sqlite (wolumen)
DATABASE_URL=file:../data/app_database.sqlite?connection_limit=1&busy_timeout=30000
