# ==============================================
# WITROS Oferty — Konfiguracja środowiskowa
# ==============================================
# Skopiuj ten plik jako .env i dostosuj wartości
# cp .env.example .env
# ==============================================

# Port na którym nasłuchuje serwer
# Na Render.com port jest automatycznie ustawiany (zwykle 10000)
PORT=10000

# Adres nasłuchiwania (0.0.0.0 = dostępny z sieci)
# NIE ZMIENIAJ na 127.0.0.1 — aplikacja nie będzie dostępna z zewnątrz
HOST=0.0.0.0

# Tryb pracy: 'development' lub 'production'
# W trybie produkcji:
# - pliki statyczne są cache'owane (szybsze ładowanie)
# - nagłówki bezpieczeństwa są aktywne
NODE_ENV=production

# ==============================================
# Bezpieczeństwo
# ==============================================

# Content-Security-Policy: permissive (default) / report-only / enforce
#   permissive   — brak CSP (tryb zgodności)
#   report-only  — CSP raportuje naruszenia, nie blokuje
#   enforce      — CSP blokuje naruszenia (wymaga migracji wszystkich inline handlerów)
# Domyślnie: permissive (zgodnie z src/app.ts)
CSP_MODE=report-only

# Hasło administratora (min. 12 znaków, wymagane tylko przy pierwszym uruchomieniu)
# UWAGA: Jeśli konto admin nie istnieje i nie ustawisz tej zmiennej,
#        aplikacja zakończy działanie z błędem.
# Ustaw w Render Dashboard jako Secret (NIE commituj wartości!)
DEFAULT_ADMIN_PASSWORD=

# ==============================================
# Monitorowanie błędów — Sentry (opcjonalnie)
# ==============================================
# DSN z https://sentry.io/settings/projects/ — jeśli pusty, Sentry wyłączony
SENTRY_DSN=

# ==============================================
# Baza danych SQLite
# ==============================================
# Lokalnie: file:./data/app_database.sqlite
# Na Render.com: file:/var/data/app_database.sqlite (Persistent Disk)
# Domyślnie Prisma szuka względem folderu prisma/, więc ścieżka
# file:../data/app_database.sqlite wskazuje na /app/data/...
# Uwaga: connection_limit=1 został usunięty — SQLite zarządza połączeniami.
#        busy_timeout ustawiany automatycznie przy starcie (PRAGMA busy_timeout=5000).
DATABASE_URL=file:../data/app_database.sqlite?busy_timeout=5000

# ==============================================
# Konfiguracja Render.com — kiedy używasz render.yaml
# ==============================================
# Render automatycznie ustawia:
# - PORT=10000 (lub inny wolny port)
# - NODE_ENV=production
# - DATABASE_URL=file:/var/data/app_database.sqlite
# - HOST=0.0.0.0
# Musisz ręcznie ustawić w dashboard Render Environment:
# - DEFAULT_ADMIN_PASSWORD (wartość secrets, NIE commituj!)
# ==============================================
